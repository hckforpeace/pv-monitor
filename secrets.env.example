# Paris-Versailles dossard monitor — environment template.
#
# Copy this file to `secrets.env` and fill in the real values:
#     cp secrets.env.example secrets.env
# `secrets.env` is gitignored; this .example file is safe to commit.
#
# Format: KEY=value, one per line, no quotes, no spaces around '='.

# ─── Required ────────────────────────────────────────────────────────────────
# Page to poll for bib availability. No URL is committed to the repo — set it here.
PV_URL=https://example.com/inscription_bourse.php
# Gmail address that sends the alerts.
PV_SMTP_USER=you@gmail.com
# Gmail APP PASSWORD (16 chars, requires 2FA enabled). A normal password fails.
# Create one at: https://myaccount.google.com/apppasswords
PV_SMTP_PASS=xxxxxxxxxxxxxxxx
# Where the "bib available" alert is sent.
PV_MAIL_TO=you@example.com

# ─── Optional feature ────────────────────────────────────────────────────────
# 2nd address alerted ONLY when the site request itself fails (non-2xx / network
# error). Leave unset/commented to disable failure emails (you still get the log).
# Throttled to at most 1 email / 30 min while the site is down.
#PV_MAIL_TO_ERRORS=alerts@example.com

# ─── Optional tuning (defaults shown) ────────────────────────────────────────
# From: header. Defaults to PV_SMTP_USER (Gmail usually rewrites it anyway).
#PV_MAIL_FROM=you@gmail.com
# SMTP server / port (STARTTLS).
#PV_SMTP_HOST=smtp.gmail.com
#PV_SMTP_PORT=587
# Seconds between checks.
#PV_INTERVAL=60
# Rotating log line cap (~2 days at 1 check/min).
#PV_LOG_MAX_LINES=2880

# ─── Testing helpers (normally unset) ────────────────────────────────────────
# Pretend a bib is available, to test the alert path.
#PV_FORCE_AVAILABLE=1
# File paths inside the container (match the volume mounts).
#PV_STATE_FILE=/data/state.json
#PV_LOG_FILE=/logs/monitor.log
